<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="#0F0F1A" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏱ Pump Timer" android:textSize="24sp" android:textColor="#FFD700" android:textStyle="bold" android:layout_marginBottom="28dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Crop Type" android:textSize="14sp" android:textColor="#AAAAAA" android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerCrop"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="24dp"
        android:background="#AAAAAA" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select Land Size" android:textSize="14sp" android:textColor="#AAAAAA" android:layout_marginBottom="8dp"/>
    <Spinner android:id="@+id/spinnerAcres" android:layout_width="match_parent" android:layout_height="48dp" android:background="#AAAAAA" android:layout_marginBottom="32dp"/>
    <!--  Result card  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal" android:background="#1A1A2E" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Run pump for" android:textSize="14sp" android:textColor="#888888"/>
        <TextView android:id="@+id/tvResult" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60 minutes" android:textSize="36sp" android:textColor="#FFD700" android:textStyle="bold" android:layout_marginTop="6dp"/>
    </LinearLayout>
</LinearLayout>